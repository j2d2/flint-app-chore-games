{
  "name": "chore-games-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Express + SQLite + Socket.io backend for Chore Games PWA",
  "scripts": {
    "dev": "lsof -ti:${PORT:-18340} | xargs kill -9 2>/dev/null; ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
